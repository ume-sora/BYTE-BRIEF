{
  "name": "bytebrief-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "postinstall": "find node_modules -name hermesc -type f -exec chmod +x {} \\; 2>/dev/null || true",
    "start": "expo start",
    "dev:android": "expo start --android",
    "build:preview": "npx eas-cli build --platform android --profile preview",
    "build:android": "npx eas-cli build --platform android --profile production",
    "submit:android": "npx eas-cli submit --platform android --profile production",
    "update": "npx eas-cli update --branch production --message",
    "__note__": "--- iOS scripts below: enable after Apple Developer signup ---",
    "dev:ios_DISABLED": "expo start --ios",
    "build:ios_DISABLED": "eas build --platform ios --profile production",
    "build:preview:ios_DISABLED": "eas build --platform ios --profile preview",
    "submit:ios_DISABLED": "eas submit --platform ios --profile production",
    "build:all_DISABLED": "eas build --platform all --profile production",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@babel/core": "^7.29.0",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.5.2",
    "@tanstack/query-async-storage-persister": "^5.90.24",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-persist-client": "^5.90.24",
    "babel-preset-expo": "^55.0.11",
    "expo": "~55.0.6",
    "expo-background-fetch": "~55.0.9",
    "expo-constants": "^55.0.7",
    "expo-font": "~55.0.4",
    "expo-linking": "^55.0.7",
    "expo-notifications": "~55.0.12",
    "expo-router": "~55.0.5",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-task-manager": "~55.0.9",
    "expo-web-browser": "~55.0.9",
    "fast-xml-parser": "^4.5.0",
    "i18next": "^25.8.17",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-i18next": "^16.5.6",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-webview": "13.16.0",
    "zustand": "^5.0.11",
    "babel-plugin-module-resolver": "^5.0.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.10",
    "typescript": "~5.9.2"
  },
  "private": true,
  "packageManager": "npm@10.9.2"
}

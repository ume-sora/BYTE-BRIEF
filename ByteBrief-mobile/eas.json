{
  "cli": {
    "version": ">= 10.0.0",
    "appVersionSource": "remote",
    "build": {
      "preview": {
        "buildHook": {
          "pre-install": "eas-build-hooks/pre-install.sh",
          "post-install": "eas-build-hooks/post-install.sh"
        }
      }
    }
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "node": "20.19.4",
      "android": { "buildType": "apk" },
      "prebuildCommand": "true"
    },
    "preview": {
      "distribution": "internal",
      "node": "20.19.4",
      "android": {
        "buildType": "apk"
      },
      "prebuildCommand": "true"
    },
    "production": {
      "node": "20.19.4",
      "android": { "buildType": "app-bundle" },
      "prebuildCommand": "true"
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-play-service-account.json",
        "track": "production"
      }
    }
  }
}

